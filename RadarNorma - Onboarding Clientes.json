      "id": "6383b8d4-26d1-4297-a039-8e2ce167e45b",
      "name": "Consultar ARCA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        -176
      ],
      "onError": "continueRegularOutput"
