    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nif (!data.resultado || !data.resultado.personaReturn) {\n  return { json: { error: true, cuit: data.cuit || 'desconocido' } };\n}\nconst persona = data.resultado.personaReturn;\nconst general = persona.datosGenerales;\n\nconst razonSocial = general.tipoPersona === 'FISICA'\n  ? `${general.apellido} ${general.nombre}`\n  : general.razonSocial || '';\n\nconst provincia = general.domicilioFiscal?.descripcionProvincia || '';\nconst cierre = parseInt(general.mesCierre) || 12;\n\nconst normalizarImp = (imp) => {\n  const l = imp.toLowerCase();\n  if (l.includes('ganancia')) return 'Ganancias';\n  if (l.includes('valor agregado') || l.includes('iva')) return 'IVA';\n  if (l.includes('monotributo')) return 'Monotributo';\n  if (l.includes('bienes personales')) return 'Bienes Personales';\n  if (l.includes('seguridad social') || l.includes('empleador')) return 'Seguridad Social';\n  if (l.includes('ingresos brutos') || l.includes('iibb')) return 'IIBB';\n  if (l.includes('aduana')) return 'Aduana';\n  return null;\n};\n\nconst impuestosRaw = [];\n\nif (persona.datosMonotributo?.impuesto) {\n  const imp = persona.datosMonotributo.impuesto;\n  if (Array.isArray(imp)) imp.forEach(i => impuestosRaw.push(i.descripcionImpuesto));\n  else impuestosRaw.push(imp.descripcionImpuesto);\n}\n\nif (persona.datosRegimenGeneral?.impuesto) {\n  const imp = persona.datosRegimenGeneral.impuesto;\n  if (Array.isArray(imp)) imp.forEach(i => impuestosRaw.push(i.descripcionImpuesto));\n  else impuestosRaw.push(imp.descripcionImpuesto);\n}\n\nconst impuestos = [...new Set(impuestosRaw.map(normalizarImp).filter(Boolean))];\n\nlet tipo = 'responsable_inscripto';\nif (impuestos.includes('Monotributo')) tipo = 'monotributista';\n\nconst actividad = persona.datosMonotributo?.actividad?.descripcionActividad\n  || persona.datosRegimenGeneral?.actividad?.descripcionActividad\n  || '';\n\nreturn {\n  json: {\n    cuit: general.idPersona,\n    razon_social: razonSocial.trim(),\n    actividad: actividad,\n    provincia: provincia,\n    impuestos: impuestos.join(', '),\n    tipo: tipo,\n    cierre: cierre\n  }\n};"
      },
