        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"cuit\": \"23390978634\",\n  \"params\": { \"idPersona\": \"{{ $json.CUIT.toString().replace(/[^0-9]/g, '') }}\" }\n}",
        "options": {}
